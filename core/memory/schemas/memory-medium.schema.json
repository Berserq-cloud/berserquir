{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "berserqir/memory-medium",
  "title": "memory-medium — sprint tracker (machine-consumed, TTL: sprint)",
  "type": "object",
  "required": ["currentMilestone", "features", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "currentMilestone": { "type": "string" },
    "goal": { "type": "string" },
    "progress": { "type": "integer", "minimum": 0, "maximum": 100 },
    "updatedAt": { "type": "string", "format": "date" },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "owner"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^FEAT-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$" },
          "name": { "type": "string" },
          "status": { "enum": ["planned", "in-progress", "blocked", "done", "superseded"] },
          "owner": { "type": "string", "description": "compiled agent name" },
          "priority": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "method": { "enum": ["RICE", "MoSCoW"] },
              "score": { "type": "string" }
            }
          },
          "acceptance": { "type": "array", "items": { "type": "string" }, "description": "EARS criteria" },
          "completedAt": { "type": "string", "format": "date" }
        }
      }
    },
    "technicalDebt": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^DEBT-[0-9]{3,}$" },
          "title": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high"] },
          "owner": { "type": "string" }
        }
      }
    },
    "adrsActive": { "type": "array", "items": { "type": "string", "pattern": "^ADR-[0-9]{3,}$" } },
    "counters": {
      "type": "object",
      "additionalProperties": { "type": "integer" },
      "description": "task/handoff/eval counters bumped by hooks and agents"
    }
  }
}
